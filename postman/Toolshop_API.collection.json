{
  "info": {
    "name": "Toolshop API — Store New Product",
    "_postman_id": "toolshop-api-collection-v1",
    "description": "Postman collection for Toolshop v5.0 API.\nCovers: authentication (login) and creating a new product.\nAPI base: https://api.practicesoftwaretesting.com\nDocumentation: https://api.practicesoftwaretesting.com/api/documentation",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "created_product_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Login — Get Access Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// TC-API-001: Login returns a valid Bearer token",
              "",
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response contains access_token', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('access_token');",
              "    pm.expect(json.access_token).to.be.a('string').and.not.be.empty;",
              "});",
              "",
              "pm.test('Token type is Bearer', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json.token_type).to.eql('Bearer');",
              "});",
              "",
              "// Store the token for subsequent requests",
              "const token = pm.response.json().access_token;",
              "pm.collectionVariables.set('access_token', token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/users/login",
          "host": ["{{base_url}}"],
          "path": ["users", "login"]
        },
        "description": "Authenticates an admin user and stores the access_token as a collection variable for use in subsequent requests."
      },
      "response": []
    },
    {
      "name": "2. Get Categories — Resolve Category ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response contains data array', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('data');",
              "    pm.expect(json.data).to.be.an('array').and.not.be.empty;",
              "});",
              "",
              "// Store the first category ID for use in product creation",
              "const categories = pm.response.json().data;",
              "if (categories && categories.length > 0) {",
              "    pm.collectionVariables.set('category_id', categories[0].id);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/categories",
          "host": ["{{base_url}}"],
          "path": ["categories"]
        },
        "description": "Fetches available categories and stores the first category ID as a collection variable."
      },
      "response": []
    },
    {
      "name": "3. Get Brands — Resolve Brand ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response contains data array', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('data');",
              "    pm.expect(json.data).to.be.an('array').and.not.be.empty;",
              "});",
              "",
              "// Store the first brand ID for use in product creation",
              "const brands = pm.response.json().data;",
              "if (brands && brands.length > 0) {",
              "    pm.collectionVariables.set('brand_id', brands[0].id);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/brands",
          "host": ["{{base_url}}"],
          "path": ["brands"]
        },
        "description": "Fetches available brands and stores the first brand ID as a collection variable."
      },
      "response": []
    },
    {
      "name": "4. POST /products — Store New Product",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// TC-API-002: POST /products creates a new product",
              "",
              "pm.test('Status code is 201 or 200', function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
              "});",
              "",
              "pm.test('Response body contains an id', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('id');",
              "    pm.expect(json.id).to.be.a('string').and.not.be.empty;",
              "});",
              "",
              "pm.test('Response name matches request name', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json.name).to.eql('Automation Test Drill Pro 3000');",
              "});",
              "",
              "pm.test('Response price matches request price', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(parseFloat(json.price)).to.eql(49.99);",
              "});",
              "",
              "pm.test('Response contains category_id', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('category_id');",
              "});",
              "",
              "pm.test('Response content-type is JSON', function () {",
              "    pm.response.to.have.header('Content-Type');",
              "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
              "});",
              "",
              "// Store the created product ID for potential cleanup",
              "const productId = pm.response.json().id;",
              "if (productId) {",
              "    pm.collectionVariables.set('created_product_id', productId);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{access_token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Automation Test Drill Pro 3000\",\n  \"description\": \"A high-performance drill created via automated API test.\",\n  \"price\": 49.99,\n  \"category_id\": \"{{category_id}}\",\n  \"brand_id\": \"{{brand_id}}\",\n  \"is_location_offer\": false,\n  \"is_rental\": false,\n  \"co2_rating\": \"A\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/products",
          "host": ["{{base_url}}"],
          "path": ["products"]
        },
        "description": "Creates a new product using a valid Bearer token.\n\nAssertions:\n- Status 200 or 201\n- Response contains an `id`\n- Response `name` matches the request payload\n- Response `price` matches the request payload\n- Response contains `category_id`\n- Content-Type header is application/json"
      },
      "response": []
    },
    {
      "name": "5. GET /products/:id — Verify Product Was Created",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Product id matches created product', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json.id).to.eql(pm.collectionVariables.get('created_product_id'));",
              "});",
              "",
              "pm.test('Product name matches', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json.name).to.eql('Automation Test Drill Pro 3000');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/products/{{created_product_id}}",
          "host": ["{{base_url}}"],
          "path": ["products", "{{created_product_id}}"]
        },
        "description": "Verifies the product created in step 4 can be retrieved by its ID."
      },
      "response": []
    },
    {
      "name": "6. POST /products — Unauthorized (No Token)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Negative test: creating a product without auth should fail",
              "",
              "pm.test('Status code is 401 Unauthorized', function () {",
              "    pm.response.to.have.status(401);",
              "});",
              "",
              "pm.test('Response contains error message', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('message');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Unauthorized Product\",\n  \"description\": \"This should not be created.\",\n  \"price\": 9.99\n}"
        },
        "url": {
          "raw": "{{base_url}}/products",
          "host": ["{{base_url}}"],
          "path": ["products"]
        },
        "description": "Negative test: attempts to create a product without a Bearer token. Expects 401 Unauthorized."
      },
      "response": []
    }
  ]
}
